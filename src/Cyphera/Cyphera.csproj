<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>Cyphera</PackageId>
    <Version>0.0.1-alpha.1</Version>
    <Authors>Horizon Digital Engineering</Authors>
    <Company>Horizon Digital Engineering LLC</Company>
    <Description>Data protection SDK for .NET. Format-preserving encryption (FF1/FF3), masking, hashing. Policy-driven protect/access API.</Description>
    <PackageTags>encryption;fpe;format-preserving;ff1;ff3;data-protection;masking;hashing</PackageTags>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/cyphera-labs/cyphera-dotnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/cyphera-labs/cyphera-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
